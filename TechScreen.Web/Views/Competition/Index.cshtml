@model TechScreen.Web.Controllers.CompetitionController.CompetitionsViewModel

@{
    ViewData["Title"] = @Model.TenantName;
}

<div>
    <h1>@Model.TenantName Competitions</h1>

    @if (Model.Competitions.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Competition</th>
                    <th>Teams</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var competition in Model.Competitions)
                {
                    <tr>
                        <td>
                            <a href="#"
                               hx-get="@Url.Action("Index", "Standings", new { competition = competition.Name })"
                               hx-target="#standings-modal"
                               hx-swap="innerHTML">
                                @competition.Name
                            </a>
                        </td>
                        <td>@competition.TeamCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div id="standings-modal" class="modal fade" tabindex="-1">
</div>

@section Scripts {
    <script>
        document.body.addEventListener('htmx:afterSwap', function (event) {
            if (event.detail.target.id === 'standings-modal') {
                var modal = new bootstrap.Modal(event.detail.target);
                modal.show();
            }
        });
    </script>
}
